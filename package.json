{
  "name": "app-chatters",
  "version": "1.1.5",
  "type": "module",
  "description": "Corporate Communication Platform",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "electron": "electron .",
    "preview": "vite preview",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "api": "^6.1.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vueuse/core": "^10.11.1",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "lucide-vue-next": "^0.344.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.38",
    "radix-vue": "^1.9.0",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.6",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue-sonner": "^2.0.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.chatters.app",
    "productName": "APP Chatters",
    "asar": true,
    "directories": {
      "buildResources": "public",
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "santibdev",
      "repo": "ESSENZA-APP"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
