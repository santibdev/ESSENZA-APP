{
  "name": "essenzamodels",
  "version": "1.1.0",
  "author": "SB TECHNOLOGY",
  "type": "module",
  "description": "Corporate Communication Platform",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development VITE_APP_VERSION=1.1.1 electron .\"",
    "build": "vite build",
    "electron": "electron .",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "api": "^6.1.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vueuse/core": "^10.11.1",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "lucide-vue-next": "^0.344.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.38",
    "radix-vue": "^1.9.0",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.2.6",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue-sonner": "^2.0.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.essenzamodels.monitor",
    "productName": "ESSENZA MODELS",
    "asar": true,
    "directories": {
      "buildResources": "public",
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "santibdev",
      "repo": "ESSENZA-APP",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/essenza.ico"
    },
    "mac": {
      "category": "public.app-category.business",
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "target": [
        "dmg"
      ],
      "icon": "public/essenza.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "shortcutName": "ESSENZA MODELS",
      "uninstallDisplayName": "Desinstalar ESSENZA MODELS",
      "installerIcon": "public/essenza.ico",
      "uninstallerIcon": "public/essenza.ico"
    }
  }
}
